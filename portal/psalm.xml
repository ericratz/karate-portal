<?xml version="1.0"?>
<psalm
    errorLevel="3"
    phpVersion="8.4"
    resolveFromConfigFile="true"
    findUnusedBaselineEntry="false"
    findUnusedCode="false"
    allFunctionsGlobal="true"
    allConstantsGlobal="true"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xmlns="https://getpsalm.org/schema/config"
    xsi:schemaLocation="https://getpsalm.org/schema/config vendor/vimeo/psalm/config.xsd"
    errorBaseline="psalm-baseline.xml"
    cacheDirectory=".psalm-cache"
>
    <projectFiles>
        <directory name="." />
        <ignoreFiles allowMissingFiles="true">
            <directory name="vendor" />
            <file name="composer-setup.php" />
        </ignoreFiles>
    </projectFiles>

    <!-- The TaintedHeader suppression for admin/student_edit.php was removed in
         the Psalm 6 upgrade: V4.2 reduced that file to a redirect stub, so the
         suppression no longer matched anything and Psalm 6 reports unused
         suppressions as errors (UnusedIssueHandlerSuppression). -->
</psalm>
